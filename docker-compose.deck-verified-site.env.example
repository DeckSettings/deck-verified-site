#@ Placement
#-  - PLACEMENT_CONSTRAINT_CACHE -
#-    Configure a placement constraint for the cache container.
PLACEMENT_CONSTRAINT_CACHE=node.hostname==<hostname>
#-  - PLACEMENT_CONSTRAINT_TASKS -
#-    Configure a placement constraint for the tasks container.
PLACEMENT_CONSTRAINT_TASKS=node.platform.os==linux
#-  - PLACEMENT_CONSTRAINT_API -
#-    Configure a placement constraint for the API container.
PLACEMENT_CONSTRAINT_API=node.role==worker
#-  - PLACEMENT_CONSTRAINT_WEB -
#-    Configure a placement constraint for the web container.
PLACEMENT_CONSTRAINT_WEB=node.platform.os==linux
#@ Replication
#-  - REPLICAS_API -
#-    Number of replicas for the backend API service.
REPLICAS_API=2
#-  - REPLICAS_WEB -
#-    Number of replicas for the web frontend service.
REPLICAS_WEB=2
#-  - REPLICAS_WEB_SSR -
#-    Number of replicas for the frontend SSR service.
REPLICAS_WEB_SSR=1
#@ Node Config
#-  - NODE_OPTIONS -
#-    Node.js options to pass to the runtime.
#-    Set to "--no-network-family-autoselection" to disable "Happy Eyeballs" and force IPv4.
#-    This is useful in environments (like Docker Swarm overlay networks) where IPv6 is resolved
#-    but has no egress, causing long timeouts as Node.js attempts to connect via IPv6 first.
NODE_OPTIONS="--no-network-family-autoselection"
#@ Resource Limits
#-  - REDIS_MEMLIMIT -
#-    Memory limit for the Redis service.
REDIS_MEMLIMIT=100M
#-  - TASKS_MEMLIMIT -
#-    Memory limit for the tasks service.
TASKS_MEMLIMIT=200M
#-  - API_MEMLIMIT -
#-    Memory limit for the API service.
API_MEMLIMIT=150M
#-  - WEB_SSR_MEMLIMIT -
#-    Memory limit for the web SSR service.
WEB_SSR_MEMLIMIT=160M
#-  - WEB_MEMLIMIT -
#-    Memory limit for the web frontend service.
WEB_MEMLIMIT=50M
#@ SSR Diagnostics
#-  - SSR_MEMORY_TELEMETRY_INTERVAL_MS -
#-    Emit structured memory telemetry every 30 seconds. Capture one heap snapshot per
#-    process when Node RSS reaches 70% of the container limit, retaining the newest 3.
#-    Set the snapshot percentage to 0 to disable automatic capture.
SSR_MEMORY_TELEMETRY_INTERVAL_MS=30000
#-  - SSR_HEAP_SNAPSHOT_RSS_PERCENT -
#-    Percent of container limit memory at which to capture heap snapshot.
SSR_HEAP_SNAPSHOT_RSS_PERCENT=70
#-  - SSR_HEAP_SNAPSHOT_RETAIN_COUNT -
#-    Number of heap snapshots to retain.
SSR_HEAP_SNAPSHOT_RETAIN_COUNT=3
#@ Traefik Config
#-  - TRAEFIK_ROUTE_RULE_API -
#-    Traefik routing rule for the backend API service.
TRAEFIK_ROUTE_RULE_API=Host(`deckverified.games`) && PathPrefix(`/deck-verified/api`)
#-  - TRAEFIK_ROUTE_RULE_WEB -
#-    Traefik routing rule for the web frontend service.
TRAEFIK_ROUTE_RULE_WEB=Host(`deckverified.games`)
#@ Container Config
#-  - ENVIRONMENT_NAME -
#-    Environment name (e.g. production, staging, test).
ENVIRONMENT_NAME=test
#-  - SENTRY_DSN -
#-    Sentry DSN for error reporting.
SENTRY_DSN=
#-  - SENTRY_ENVIRONMENT -
#-    Sentry environment tag.
SENTRY_ENVIRONMENT=prod
#-  - SENTRY_TRACES_SAMPLE_RATE_TASKS -
#-    Sentry traces sample rate for tasks.
SENTRY_TRACES_SAMPLE_RATE_TASKS=0.1
#-  - SENTRY_PROFILES_SAMPLE_RATE_TASKS -
#-    Sentry profiles sample rate for tasks.
SENTRY_PROFILES_SAMPLE_RATE_TASKS=0.1
#-  - SENTRY_TRACES_SAMPLE_RATE_API -
#-    Sentry traces sample rate for API.
SENTRY_TRACES_SAMPLE_RATE_API=0.1
#-  - SENTRY_PROFILES_SAMPLE_RATE_API -
#-    Sentry profiles sample rate for API.
SENTRY_PROFILES_SAMPLE_RATE_API=0.1
#-  - REDIS_PASSWORD -
#-    Password for the Redis cache.
REDIS_PASSWORD=password
#-  - GITHUB_WORKFLOW_SECRET -
#-    An optional secret used to validate GitHub workflow webhook requests. If not set, workflow updates will be disabled.
GITHUB_WORKFLOW_SECRET=XXXXXXXXXXX
#-  - API_GH_TOKEN -
#-    A GitHub token for read access for the api service to the DeckSettings GitHub org/repo API
API_GH_TOKEN=XXXXXXXXXXX
#-  - TASKS_GH_TOKEN -
#-    A GitHub token for read access for the tasks service to the DeckSettings GitHub org/repo API
TASKS_GH_TOKEN=XXXXXXXXXXX
#-  - GITHUB_APP_CLIENT_ID -
#-    GitHub App client ID (optional) for enabling user logins.
GITHUB_APP_CLIENT_ID=
#-  - GITHUB_APP_CLIENT_SECRET -
#-    GitHub App client secret (optional) for enabling user logins.
GITHUB_APP_CLIENT_SECRET=
#-  - BLOGGER_API_KEY -
#-    Blogger API key (optional) used by backend for generating blog posts summarizing game reports.
BLOGGER_API_KEY=
#-  - ISTHEREANYDEAL_API_KEY -
#-    IsThereAnyDeal API key (optional) used for checking game prices.
ISTHEREANYDEAL_API_KEY=
#-  - DEFAULT_CACHE_TIME -
#-    The default time to cache game information. This mostly is used to avoid GitHub rate limiting.
DEFAULT_CACHE_TIME=21600
#-  - REVERSE_PROXY_COUNT -
#-    A count of reverse proxy's that the service is behind
REVERSE_PROXY_COUNT=0
#-  - DISABLE_RATE_LIMITER -
#-    Disable the rate limiter. Should normally be false for production.
DISABLE_RATE_LIMITER=true
#-  - RUN_SCHEDULED_TASKS_ON_START -
#-    Run the scheduled tasks on container start. Should normally be false for production.
RUN_SCHEDULED_TASKS_ON_START=true
#-  - BASE_URL -
#-    The base URL of the site/application.
BASE_URL=https://deckverified.games
#-  - PUBLIC_WEB_ORIGINS -
#-    Comma-separated list of allowed public web origins for auth endpoints (CORS).
PUBLIC_WEB_ORIGINS=https://deckverified.games
#-  - DV_AUTH_JWT_SECRET -
#-    JWT secret for backend user authentication.
DV_AUTH_JWT_SECRET=XXXXXXXXXXX
#@ Fluentd Logging
#-  - FLUENTD_PORT -
#-    Host Fluentd listener port used by the Docker logging driver.
FLUENTD_PORT=24226
